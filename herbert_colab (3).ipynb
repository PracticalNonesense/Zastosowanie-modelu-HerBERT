      },
      "source": [
        "## Funkcje pomocnicze"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-4",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "cell-4",
        "outputId": "e6f98e34-5fe1-462b-b55e-3e7675208097"
      },
      "outputs": [
        {
          "output_type": "stream",
